# Environment variables for AleTrackApp
# Zkopírujte do .env nebo .env.local a upravte dle potřeby.
# Vite načítá: .env, .env.local, .env.[mode], .env.[mode].local
# Používané módy (viz package.json scripts): localhost, dev, production

# Lokální backend (výchozí)
VITE_API_BASE_URL=http://localhost:8080

# Příklad pro testovací prostředí (mód dev)
# VITE_API_BASE_URL=https://dev.api.aletrack.local

# Příklad pro produkci (mód production)
# VITE_API_BASE_URL=https://api.aletrack.cz

# Adresa společnosti (používá se při plánování tras)
VITE_COMPANY_ADDRESS={"streetName":"Turistická","streetNumber":"211","city":"Hrádek nad Nisou","zip":"46334","country":"Czechia","latitude":50.841437,"longitude":14.837309}

